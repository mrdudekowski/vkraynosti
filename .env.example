VITE_TOUR_REQUEST_ENDPOINT_URL=https://script.google.com/macros/s/AKfycbzAR5OFGX5ds8orq95mdb-xJRIJY0PAIlJ8TUIzbOas_YHM0ujC_qagvfHjQsnjCVafIg/exec

# Публичный URL S3/CDN для runtime JSON туров (без деплоя при обновлении).
# Prod: https://YOUR-CDN-OR-S3-ORIGIN/ (часто совпадает с VITE_PUBLIC_ASSET_BASE_URL).
# Dev/E2E: пусто → fallback на public/data/tour-schedule/*.json через BASE_URL.
VITE_PUBLIC_S3_BASE_URL=

# CDN/S3 origin для туровых медиа (team, banners, safety). Пусто = из public/ через BASE_URL.
# VITE_PUBLIC_ASSET_BASE_URL=https://YOUR-CDN-OR-S3-ORIGIN/

# ID счётчика Яндекс.Метрики (пусто = аналитика не инициализируется даже при согласии)
VITE_YANDEX_METRIKA_ID=

# Cutover (web-vkr / TimeWeb prod):
# VITE_SITE_URL=https://vkraynosti.ru
# VITE_BASE_PATH=/

# S3 sync (npm run sync:s3) — см. TimeWebDoc/examples/s3.env.example
