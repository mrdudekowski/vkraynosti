# TimeWeb S3 sync (npm run sync:s3) — не коммитить реальные ключи
# Скопируйте в .env.local или экспортируйте в shell перед sync

# Бакет и endpoint (панель TimeWeb → S3)
# Endpoint = поле «S3 URL» (без имени бакета)
S3_BUCKET=1beb22d2-76b9-47e6-bbf0-5c9cc8d51ea7
AWS_ENDPOINT_URL=https://s3.twcstorage.ru
# Альтернативное имя (скрипт принимает оба):
# S3_ENDPOINT_URL=https://s3.twcstorage.ru

# Опционально: префикс внутри бакета (обычно пусто — ключи = tours/…)
# S3_PREFIX=

# Учётные данные (IAM / ключи S3 в TimeWeb — только локально или GitHub Secrets)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Публичный origin для проверки после заливки (= VITE_PUBLIC_ASSET_BASE_URL на web-vkr)
# Прямой URL бакета (без CDN):
S3_PUBLIC_BASE_URL=https://s3.twcstorage.ru/1beb22d2-76b9-47e6-bbf0-5c9cc8d51ea7/
# Пример CDN:
# S3_PUBLIC_BASE_URL=https://cdn.your-domain.ru/

# Связь с Vite (ветка web-vkr, сборка TimeWeb):
# VITE_PUBLIC_ASSET_BASE_URL=https://s3.twcstorage.ru/1beb22d2-76b9-47e6-bbf0-5c9cc8d51ea7/
# Тот же https origin при сборке добавляется в CSP (img-src, media-src) — см. contentSecurityPolicy.ts
