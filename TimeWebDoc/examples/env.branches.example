# Пример env по веткам (не коммитить реальные значения)

# --- main (разработка, тесты, GitHub Pages) ---
# VITE_PUBLIC_ASSET_BASE_URL=
# Медиа из public/ через BASE_URL (/vkraynosti/ пока не cutover)

# --- web-vkr → TimeWeb App (ручной деплой) ---
# Туры/фото/видео/баннеры — CDN. Шрифты public/fonts/ остаются в App (BASE_URL), не сюда.
VITE_PUBLIC_ASSET_BASE_URL=https://YOUR-CDN-OR-S3-ORIGIN/
VITE_TOUR_REQUEST_ENDPOINT_URL=
VITE_TOUR_SCHEDULE_ENDPOINT_URL=
VITE_YANDEX_METRIKA_ID=
# VITE_BASE_PATH=/   # при корневом домене на TimeWeb
