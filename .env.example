VITE_TOUR_REQUEST_ENDPOINT_URL=https://script.google.com/macros/s/AKfycbyUGr2bwGQ5ge4swzRo4EByIMlWxjIFtsG-wtPFEQ71WkdQXbPpuM_3YN6ISSeb6nEPMw/exec
VITE_TOUR_SCHEDULE_ENDPOINT_URL=
# ID счётчика Яндекс.Метрики (пусто = аналитика не инициализируется даже при согласии)
VITE_YANDEX_METRIKA_ID=
# CDN/S3 origin для туровых медиа (team, banners, safety). Пусто = из public/ через BASE_URL.
# Шрифты public/fonts/ всегда с App (BASE_URL), не с этого origin.
# VITE_PUBLIC_ASSET_BASE_URL=https://YOUR-CDN-OR-S3-ORIGIN/
# При сборке web-vkr https origin из этой переменной попадает в CSP (img-src, media-src).
# CDN задан → dist без tours/team/banners/safety (lean TimeWeb artifact).

# Cutover (web-vkr / TimeWeb prod; main/Pages оставить пустым до DNS switch):
# VITE_SITE_URL=https://your-production-domain/
# VITE_BASE_PATH=/

# S3 sync (npm run sync:s3) — только локально, см. TimeWebDoc/examples/s3.env.example
# S3_BUCKET=
# AWS_ENDPOINT_URL=https://s3.twcstorage.ru
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
